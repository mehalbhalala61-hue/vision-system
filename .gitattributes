# =============================================================================
# .gitattributes — Git LFS tracking for large files
# Run once: git lfs install
# Then: git add .gitattributes → git commit → git push
# =============================================================================
# ONNX model — ~45MB, too large for regular Git
*.onnx filter=lfs diff=lfs merge=lfs -text
# PyTorch checkpoints — only if you want to version them via LFS
# (optional — usually we just keep best.pth locally)
# *.pth filter=lfs diff=lfs merge=lfs -text
# Large data files (if ever committed)
*.zip  filter=lfs diff=lfs merge=lfs -text
*.tar  filter=lfs diff=lfs merge=lfs -text
*.gz   filter=lfs diff=lfs merge=lfs -text
