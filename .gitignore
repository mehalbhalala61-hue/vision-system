# =============================================================================
# .gitignore — Vision System Capstone v3
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — NEVER commit these
# -----------------------------------------------------------------------------
.env
*.env
kaggle.json
secrets/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
.installed.cfg
lib/
lib64/

# -----------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------------
venv/
env/
.venv/
ENV/
.env.bak

# -----------------------------------------------------------------------------
# JUPYTER
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# ML ARTIFACTS — large files, use Git LFS for .onnx
# -----------------------------------------------------------------------------
logs/checkpoints/*.pth
logs/checkpoints/*.pt
*.pth
*.pt

# ONNX tracked via Git LFS (see .gitattributes)
# model.onnx → DO NOT add here, LFS handles it

# -----------------------------------------------------------------------------
# DATA — raw dataset never committed (too large)
# -----------------------------------------------------------------------------
data/raw/
data/cache/
data/processed/
data/splits/
# nutrition.csv IS committed (small, USDA sourced)
!data/nutrition.csv
!data/classes.txt

# -----------------------------------------------------------------------------
# LOGS + OUTPUTS (optional: commit final plots only)
# -----------------------------------------------------------------------------
logs/
!logs/.gitkeep

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V2
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Keep VS Code extensions/tasks config (useful for team)
!.vscode/extensions.json
!.vscode/tasks.json

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
.pytest_cache/
.coverage
htmlcov/