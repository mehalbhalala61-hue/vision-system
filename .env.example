# =============================================================================
# .env.example — Vision System Capstone v3
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR values below
#   3. NEVER commit .env to Git — it's already in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL (Railway managed)
# -----------------------------------------------------------------------------
# Local development (Docker):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vision_db
#
# Railway (auto-injected — copy from Railway dashboard → Variables):
#   DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/<db>
#
# NOTE: SQLAlchemy needs postgresql://, not postgres://
#       The db/session.py auto-fixes this with .replace()
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vision_db

# -----------------------------------------------------------------------------
# GEMINI AI
# -----------------------------------------------------------------------------
# Get from: aistudio.google.com → Get API Key (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use — flash is faster + cheaper for demo
GEMINI_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# USDA FoodData Central API
# -----------------------------------------------------------------------------
# Get from: fdc.nal.usda.gov → Get API Key (free, 3600 req/hr)
# Without key: uses DEMO_KEY (30 req/hr — enough for one-time fetch)
USDA_API_KEY=DEMO_KEY

# -----------------------------------------------------------------------------
# KAGGLE — for dataset download on Kaggle notebook
# -----------------------------------------------------------------------------
# Get from: kaggle.com → Account → API → Create New Token
# Downloads kaggle.json — copy values here
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
# Environment: development | production
APP_ENV=development

# Port (Railway auto-sets this — don't change for production)
PORT=8000

# Secret key for future auth (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR
